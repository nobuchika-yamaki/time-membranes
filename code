# Helpers
# =========================================================

def sem(x: np.ndarray) -> float:
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if x.size <= 1:
        return np.nan
    return float(np.std(x, ddof=1) / math.sqrt(x.size))


def safe_mean(x: np.ndarray) -> float:
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    return float(np.mean(x)) if x.size else np.nan


def safe_median(x: np.ndarray) -> float:
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    return float(np.median(x)) if x.size else np.nan


def safe_std(x: np.ndarray) -> float:
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    return float(np.std(x, ddof=1)) if x.size > 1 else np.nan


def fisher_ci(r: float, n: int, zcrit: float = 1.959963984540054) -> Tuple[float, float]:
    if n < 4 or not np.isfinite(r) or abs(r) >= 1:
        return np.nan, np.nan
    z = 0.5 * np.log((1.0 + r) / (1.0 - r))
    se = 1.0 / math.sqrt(n - 3)
    lo = z - zcrit * se
    hi = z + zcrit * se
    r_lo = (np.exp(2 * lo) - 1) / (np.exp(2 * lo) + 1)
    r_hi = (np.exp(2 * hi) - 1) / (np.exp(2 * hi) + 1)
    return float(r_lo), float(r_hi)


def save_csv(df: pd.DataFrame, filename: str) -> str:
