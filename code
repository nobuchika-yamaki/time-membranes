# Distribution / correlation outputs
# =========================================================

CHI_BANDS = ["<=0.5", "0.5-1", "1-2", "2-5", "5-10", ">10"]


def build_chi_distribution_table(raw_df: pd.DataFrame) -> pd.DataFrame:
    df = raw_df.copy()
    df["chi_band"] = pd.cut(
        df["chi"],
        bins=[-np.inf, 0.5, 1.0, 2.0, 5.0, 10.0, np.inf],
        labels=CHI_BANDS,
        include_lowest=True
    )

    cols = [
        "experiment", "condition_index", "trial", "seed_used",
        "control_mode", "delay_mode", "gamma", "beta", "tau", "sigma",
        "relative_spread", "k_linear",
        "chi", "t_corr", "mi_lag_tau", "acf_lag1", "acf_lag_tau",
        "trajectory_clipped", "clipped_fraction", "acf_failure_reason", "chi_band"
    ]
    cols = [c for c in cols if c in df.columns]
    return df[cols].sort_values(["experiment", "condition_index", "trial"]).reset_index(drop=True)


def build_chi_distribution_counts(table_df: pd.DataFrame) -> pd.DataFrame:
    gcols = ["experiment", "control_mode", "delay_mode", "tau", "relative_spread", "chi_band"]
    gcols = [c for c in gcols if c in table_df.columns]

    counts = table_df.groupby(gcols, dropna=False).size().reset_index(name="count")
    denom_cols = [c for c in gcols if c != "chi_band"]
    totals = table_df.groupby(denom_cols, dropna=False).size().reset_index(name="total")

    merged = counts.merge(totals, on=denom_cols, how="left")
    merged["fraction"] = merged["count"] / merged["total"]
    return merged.sort_values(denom_cols + ["chi_band"]).reset_index(drop=True)


def build_figure2_aggregated_distribution(counts_df: pd.DataFrame) -> pd.DataFrame:
    df = counts_df.copy()
    if "delay_mode" in df.columns:
        df = df[df["delay_mode"] == "fixed"].copy()
    if "control_mode" in df.columns:
        df = df[df["control_mode"].isin(["nonlinear_delay", "bounded_linear_delay", "no_delay"])].copy()

    agg = (
        df.groupby(["control_mode", "chi_band"], dropna=False)["count"]
        .sum()
        .reset_index()
    )
    totals = agg.groupby("control_mode")["count"].sum().reset_index(name="total")
    agg = agg.merge(totals, on="control_mode", how="left")
    agg["fraction"] = agg["count"] / agg["total"]

    # ensure complete band grid
    rows = []
    for control_mode in ["nonlinear_delay", "bounded_linear_delay", "no_delay"]:
        for band in CHI_BANDS:
            sub = agg[(agg["control_mode"] == control_mode) & (agg["chi_band"].astype(str) == band)]
            if len(sub) == 0:
                rows.append({"control_mode": control_mode, "chi_band": band, "count": 0, "total": np.nan, "fraction": 0.0})
            else:
                rows.append(sub.iloc[0].to_dict())

    out = pd.DataFrame(rows)
    out["chi_band"] = pd.Categorical(out["chi_band"], categories=CHI_BANDS, ordered=True)
    out = out.sort_values(["control_mode", "chi_band"]).reset_index(drop=True)
    return out


def corr_summary(df: pd.DataFrame, labels: Dict[str, object]) -> Dict[str, object]:
    sub = df[["chi", "mi_lag_tau"]].replace([np.inf, -np.inf], np.nan).dropna()
    n = len(sub)
    row = dict(labels)
    row["n"] = n

    if n < 3:
        row["pearson_r"] = np.nan
        row["spearman_rho"] = np.nan
        row["pearson_ci_low"] = np.nan
        row["pearson_ci_high"] = np.nan
        row["chi_mean"] = np.nan
        row["mi_mean"] = np.nan
        return row

    pearson_r = float(sub["chi"].corr(sub["mi_lag_tau"], method="pearson"))
    spearman_rho = float(sub["chi"].corr(sub["mi_lag_tau"], method="spearman"))
    ci_lo, ci_hi = fisher_ci(pearson_r, n)

    row["pearson_r"] = pearson_r
    row["spearman_rho"] = spearman_rho
    row["pearson_ci_low"] = ci_lo
    row["pearson_ci_high"] = ci_hi
    row["chi_mean"] = float(sub["chi"].mean())
    row["mi_mean"] = float(sub["mi_lag_tau"].mean())
    return row


def build_correlation_outputs(raw_df: pd.DataFrame) -> Tuple[pd.DataFrame, pd.DataFrame]:
    overall = pd.DataFrame([corr_summary(raw_df, {"group_type": "overall", "group_value": "all"})])

    by_control_rows = []
    for control_mode, g in raw_df.groupby("control_mode", dropna=False):
        by_control_rows.append(
            corr_summary(g, {"group_type": "control_mode", "group_value": control_mode})
        )
    by_control = pd.DataFrame(by_control_rows).sort_values("group_value").reset_index(drop=True)
    return overall, by_control


# =========================================================
# Tables / metadata
# =========================================================

def build_parameter_table(base: SimParams) -> pd.DataFrame:
    rows = [
        {"parameter": "gamma", "meaning": "dissipation rate", "value": base.gamma},
        {"parameter": "beta", "meaning": "feedback gain", "value": base.beta},
        {"parameter": "tau", "meaning": "delay", "value": base.tau},
        {"parameter": "sigma", "meaning": "noise amplitude", "value": base.sigma},
        {"parameter": "control_mode", "meaning": "feedback structure", "value": "nonlinear_delay / bounded_linear_delay / no_delay"},
        {"parameter": "delay_mode", "meaning": "delay implementation", "value": "fixed / stochastic_single_delay"},
        {"parameter": "relative_spread", "meaning": "delay std / mean delay", "value": "used for stochastic delay"},
        {"parameter": "k_linear", "meaning": "scaling inside bounded tanh", "value": base.k_linear},
        {"parameter": "dt", "meaning": "integration step", "value": "0.01 * min(tau, 1/gamma)"},
        {"parameter": "initial history", "meaning": "t < 0", "value": "Gaussian history with variance sigma^2"},
        {"parameter": "relax_time", "meaning": "burn-in duration", "value": "100 / gamma"},
        {"parameter": "analysis_time", "meaning": "post-burn-in duration", "value": base.analysis_time},
        {"parameter": "n_trials", "meaning": "independent realizations per condition", "value": base.n_trials},
    ]
    return pd.DataFrame(rows)


def build_equation_table() -> pd.DataFrame:
    rows = [
        {
            "label": "main_model",
            "equation": "dx/dt = -gamma*x(t) + beta*f(x(t-tau)) + sigma*xi(t)",
            "note": "stochastic delayed dynamics"
        },
        {
            "label": "nonlinear_delay",
            "equation": "f(x) = tanh(x)",
            "note": "applied to delayed state x(t-tau)"
        },
        {
            "label": "bounded_linear_delay",
            "equation": "f(x) = tanh(k_linear*x)",
            "note": "bounded linear-like control"
        },
        {
            "label": "no_delay",
            "equation": "f(x_now) = tanh(x_now)",
            "note": "instantaneous feedback"
        },
        {
            "label": "self_retention_index",
            "equation": "chi = gamma * T_corr",
            "note": "T_corr is first lag where ACF = 1/e"
        },
        {
            "label": "lagged_mutual_information",
            "equation": "MI_tau = I[x(t); x(t-tau)]",
            "note": "binned estimate"
        }
    ]
    return pd.DataFrame(rows)


# =========================================================
# Main
# =========================================================

def main() -> None:
    if os.path.exists(LOGFILE):
        os.remove(LOGFILE)

    base = SimParams()
    log(f"Output directory: {OUTDIR}")

    # save config tables
    save_csv(build_parameter_table(base), "parameter_table.csv")
    save_csv(build_equation_table(), "equation_table.csv")
    save_json(base.to_serializable_dict(), "run_config.json")

    # validation
    log("Running validation suite")
    validation_df = run_validation_suite(base)
    save_csv(validation_df, "validation_report.csv")
    save_json({"validation": validation_df.to_dict(orient="records")}, "validation_report.json")

    # core experiment: control comparison
    log("Running control comparison")
    control_raw, control_summary = run_experiment(
        configs=build_control_configs(base),
        experiment_name="control_comparison",
        base_seed=100_000
    )
    save_csv(control_raw, "control_comparison_raw.csv")
    save_csv(control_summary, "control_comparison_summary.csv")

    # figure 1 left panel data
    fig1_left = control_summary[
        control_summary["control_mode"].isin(["nonlinear_delay", "bounded_linear_delay", "no_delay"])
    ].copy()
    save_csv(fig1_left, "figure1_left_panel_data.csv")

    # figure 1 right / figure 3 scatter data
    fig_scatter = control_raw[
        [
            "trial", "seed_used", "control_mode", "tau", "gamma", "beta", "sigma",
            "chi", "mi_lag_tau", "t_corr", "trajectory_clipped", "acf_failure_reason"
        ]
    ].copy()
    save_csv(fig_scatter, "figure_scatter_data.csv")

    # chi distribution outputs
    log("Building chi distribution outputs")
    chi_table = build_chi_distribution_table(control_raw)
    chi_counts = build_chi_distribution_counts(chi_table)
    fig2_data = build_figure2_aggregated_distribution(chi_counts)

    save_csv(chi_table, "chi_distribution_table.csv")
    save_csv(chi_counts, "chi_distribution_counts.csv")
    save_csv(fig2_data, "figure2_distribution_data.csv")

    # correlation outputs
    log("Building correlation outputs")
    corr_overall, corr_by_control = build_correlation_outputs(control_raw)
    save_csv(corr_overall, "chi_mi_correlation_overall.csv")
    save_csv(corr_by_control, "chi_mi_correlation_by_control.csv")

    # sigma sweep
    log("Running sigma sweep")
    sigma_raw, sigma_summary = run_experiment(
        configs=build_sigma_configs(base),
        experiment_name="sigma_sweep",
        base_seed=200_000
    )
    save_csv(sigma_raw, "sigma_sweep_raw.csv")
    save_csv(sigma_summary, "sigma_sweep_summary.csv")

    # delay-dispersion sweep
    log("Running delay dispersion sweep")
    disp_raw, disp_summary = run_experiment(
        configs=build_delay_dispersion_configs(base),
        experiment_name="delay_dispersion_sweep",
        base_seed=300_000
    )
    save_csv(disp_raw, "delay_dispersion_raw.csv")
    save_csv(disp_summary, "delay_dispersion_summary.csv")

    # manuscript-ready summary table
    summary_rows = []

    # example tau = 1.20
    for control_mode in ["nonlinear_delay", "bounded_linear_delay", "no_delay"]:
        sub = control_summary[
            (control_summary["control_mode"] == control_mode)
            & (np.isclose(control_summary["tau"], 1.20))
        ]
        if len(sub):
            r = sub.iloc[0]
            summary_rows.append({
                "section": "Results 3.2 example at tau=1.20",
                "group": control_mode,
                "chi_mean": r["chi_mean"],
                "chi_sem": r["chi_sem"],
                "frac_chi_gt_1": r["frac_chi_gt_1"]
            })

    # figure 2 distribution peak bands
    for control_mode in ["nonlinear_delay", "bounded_linear_delay", "no_delay"]:
        sub = fig2_data[fig2_data["control_mode"] == control_mode].copy()
        if len(sub):
            peak = sub.sort_values("fraction", ascending=False).iloc[0]
            summary_rows.append({
                "section": "Results 3.3 dominant band",
                "group": control_mode,
                "chi_band": peak["chi_band"],
                "fraction": peak["fraction"]
            })

    # correlations
    for _, r in corr_by_control.iterrows():
        summary_rows.append({
            "section": "Results 3.4 correlations",
            "group": r["group_value"],
            "pearson_r": r["pearson_r"],
            "pearson_ci_low": r["pearson_ci_low"],
            "pearson_ci_high": r["pearson_ci_high"],
            "spearman_rho": r["spearman_rho"],
            "n": r["n"]
        })

    save_csv(pd.DataFrame(summary_rows), "manuscript_ready_summary_table.csv")

    # master file list
    created = [
        "parameter_table.csv",
        "equation_table.csv",
        "run_config.json",
        "validation_report.csv",
        "validation_report.json",
        "control_comparison_raw.csv",
        "control_comparison_summary.csv",
        "figure1_left_panel_data.csv",
        "figure_scatter_data.csv",
        "chi_distribution_table.csv",
        "chi_distribution_counts.csv",
        "figure2_distribution_data.csv",
        "chi_mi_correlation_overall.csv",
        "chi_mi_correlation_by_control.csv",
        "sigma_sweep_raw.csv",
        "sigma_sweep_summary.csv",
        "delay_dispersion_raw.csv",
        "delay_dispersion_summary.csv",
        "manuscript_ready_summary_table.csv",
        "run_log.txt"
    ]
    save_csv(pd.DataFrame({"filename": created}), "created_files_index.csv")

    log("Completed all analyses")
    for fn in created:
        log(f" - {os.path.join(OUTDIR, fn)}")


if __name__ == "__main__":
    main()
